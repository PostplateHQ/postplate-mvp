# Copy this file to .env and fill in your values
# Then restart the server: node backend/server.js

# Required for AI menu scanning, poster generation, and campaign suggestions
OPENAI_API_KEY=sk-your-key-here

# Omitted or empty defaults to true = free placeholders (local dev / CI). Set false + OPENAI_API_KEY for real AI.
DEV_MODE=true

# Optional: vision model for menu photo import (default gpt-4o-mini). Use gpt-4o for harder layouts (denser / multi-column).
# OPENAI_MENU_VISION_MODEL=gpt-4o
