{
  "name": "postplate-mvp",
  "version": "1.0.0",
  "description": "PostPlate helps restaurants launch promotions, track redemptions, and turn walk-ins into repeat customers — all in one simple platform.",
  "main": "index.js",
  "scripts": {
    "start": "node backend/server.js",
    "test": "node --test tests/*.test.js",
    "test:e2e": "node --test tests/e2e-blackbox-suite.test.js tests/e2e-llm-menu-contracts.test.js",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "playwright:install": "node scripts/playwright-install.js",
    "build:growth-home": "cd frontend/growth-home && npm install && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostplateHQ/postplate-mvp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/PostplateHQ/postplate-mvp/issues"
  },
  "homepage": "https://github.com/PostplateHQ/postplate-mvp#readme",
  "devDependencies": {
    "@playwright/test": "^1.50.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4"
  }
}
